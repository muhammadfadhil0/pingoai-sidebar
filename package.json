{
  "name": "pingoai",
  "version": "1.0.0",
  "description": "AI Integration for Dekstop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --no-sandbox",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1",
    "watcher:build": "dotnet publish native/HighlightWatcher/HighlightWatcher.csproj -c Release -o native/HighlightWatcher/bin/Publish"
  },
  "build": {
    "appId": "com.pingoai.app",
    "productName": "PingoAI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [],
  "author": "Muhammad Fadhil",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^39.2.1",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "electron-store": "^11.0.2"
  }
}
